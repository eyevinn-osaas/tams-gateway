DB_URL=<DB_URL>
DB_USERNAME=<DB_USERNAME>
DB_PASSWORD=<DB_PASSWORD>
S3_ENDPOINT_URL=<S3_ENDPOINT_URL>
S3_BUCKET=<S3_BUCKET>
AWS_ACCESS_KEY_ID=<ACCESS_KEY_ID>
AWS_SECRET_ACCESS_KEY=<SECRET_ACCESS_KEY>
# Optional. When set, the gateway enforces this bearer token on all routes
# except / , /readiness and /docs. When unset, the gateway delegates auth to an
# upstream proxy / access gate (e.g. the OSC ingress gate validating a SAT); it
# only logs a warning in production. Leave unset when running behind such a gate.
API_TOKEN=<API_TOKEN>