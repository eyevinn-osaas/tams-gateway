{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    /* Visit https://aka.ms/tsconfig to read more about this file */

    /* Language and Environment */
    "target": "es2022" /* Set the JavaScript language version for emitted JavaScript and include compatible library declarations. */,
    "lib": [
      "es5",
      "ES2015.Promise",
      "es2022"
    ] /* Specify a set of bundled library declaration files that describe the target runtime environment. */,

    /* Modules */
    "module": "preserve" /* Preserve module syntax; the esbuild-based toolchain (tsx/vitest) handles emit. */,
    "resolveJsonModule": true /* Enable importing .json files. */,
    "moduleResolution": "bundler" /* Matches the bundler/transpiler runtime (tsx, vitest, esbuild). */
  },
  // src/api/ui holds browser static assets (hand-written inspector JS + vendored
  // hls.min.js), not Node/TypeScript source. They are served verbatim by
  // @fastify/static, never compiled, so they are excluded from the Node program
  // (the Node tsconfig has no DOM lib and checkJs would flag browser globals).
  "exclude": ["node_modules", "*.config.js", "scripts", "src/api/ui"]
}
